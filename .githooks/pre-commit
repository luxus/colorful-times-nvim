#!/bin/sh
# Pre-commit hook for colorful-times.nvim
# Runs luacheck on staged Lua files before allowing commit

# Get list of staged Lua files
STAGED_LUA_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.lua')

# If no Lua files are staged, exit successfully
if [ -z "$STAGED_LUA_FILES" ]; then
    exit 0
fi

# Check if luacheck is installed
if ! command -v luacheck >/dev/null 2>&1; then
    echo "⚠️  Warning: luacheck not found. Skipping lint check."
    echo "   Install luacheck to enable pre-commit linting:"
    echo "   - macOS: brew install luacheck"
    echo "   - Ubuntu/Debian: sudo apt-get install lua-check"
    echo "   - LuaRocks: luarocks install luacheck"
    exit 0
fi

echo "🔍 Running luacheck on staged Lua files..."

# Run luacheck on staged files
# Use .luacheckrc for configuration
if ! luacheck $STAGED_LUA_FILES; then
    echo "❌ luacheck found issues. Commit aborted."
    echo "   Fix the errors above and try again."
    exit 1
fi

echo "✅ luacheck passed. Proceeding with commit."
exit 0
